# Rate limiting
REDIS_URL=                        # optional, falls back to memory

# Bot detection
TURNSTILE_SECRET=                 # Cloudflare Turnstile secret key
HONEYPOT_FIELD=_hp

# IP filtering
BLOCKED_IPS=                      # comma-separated, e.g. 1.2.3.4,5.6.7.8
BLOCKED_COUNTRIES=                # comma-separated ISO codes, e.g. RU,KP
IPINFO_TOKEN=                     # ipinfo.io token (free tier)

# Validation
MAX_FIELD_LENGTH=10000

# General
NODE_ENV=development
